<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyScan</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="luxury-dark">

    <div class="dynamic-bg" style="background-image: url('@(ViewData["BgImage"] ?? "/images/default-dark.jpg")');"></div>

    <div class="container-fluid min-vh-100 d-flex flex-column">
        <header class="glass-nav my-3 mx-2 p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="logo fw-bold text-white">SKYSCAN <span class="text-warning">PREMIUM</span></div>
                <div class="text-white-50">Welcome, @ViewData["UserName"]</div>
            </div>
        </header>

        <div class="row flex-grow-1 px-2">
            <aside class="col-md-3">
                <div class="glass-card h-100 p-3">
                    @RenderSection("Sidebar", required: false)
                </div>
            </aside>

            <main class="col-md-9">
                <div class="glass-card h-100 p-4">
                    @RenderBody()
                </div>
            </main>
        </div>

        <footer class="mt-auto py-4 text-center text-white-50">
            <small>&copy; 2026 SkyScan Celestial - Private Aviation Portal</small>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>