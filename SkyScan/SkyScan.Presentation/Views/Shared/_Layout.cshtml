<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyScan Celestial</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary": "#dac76a",
                        "primary": "#bfc5e4",
                        "on-primary": "#292f48",
                        "surface-dim": "#0b1229",
                        "background": "#0b1229",
                        "on-background": "#dce1ff",
                        "surface-container-low": "#141a32",
                        "surface-container-high": "#222941",
                        "outline-variant": "#46464d"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "manrope": ["Manrope"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24; }
        .glass-panel { background: rgba(45, 52, 76, 0.4); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); }
        .atmospheric-layer { background: linear-gradient(180deg, rgba(11, 18, 41, 0) 0%, rgba(11, 18, 41, 0.95) 100%); }
        body { background-color: #0b1229; color: #dce1ff; }
    </style>
</head>
<body class="bg-background text-on-background font-body selection:bg-tertiary selection:text-on-tertiary">
    <!-- Top Navigation -->
    <nav class="fixed top-0 w-full z-50 bg-[#0B1229]/60 backdrop-blur-2xl shadow-[0px_24px_48px_rgba(6,13,36,0.4)]">
        <div class="flex justify-between items-center px-12 py-6 w-full max-w-screen-2xl mx-auto h-20">
            <div class="flex items-center gap-4">
                <img alt="SkyScan Logo" class="w-8 h-8 object-contain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDE3YoV-bTiqbWTeJ5H9ZF2xASvIl5pQvAFUdV7bL55V12L4dN4XEyRIVXFwZtR2g_vU7STh65kAHVvr9Q7zJiexI8ZwwfUvBDXLdgzEBdnjMDLMiG1inSnqltW_N7vSXX48JjoP7lT4NpRt6KTiJ6dPPBNf8Gl7mEyMBiEIbLf8kbZKT3T9dEx7CwRyl8W4DZcqXFchICzuoza_A2IXwkyBIp9tffc9wpL1gi1sE-cPjK71kDv28DSgFeXtwHG9f8tPUGOpkQUsQ" />
                <div class="text-2xl font-black tracking-tighter text-[#BFC5E4] font-headline">SkyScan</div>
            </div>
            <div class="hidden md:flex items-center gap-10 font-manrope tracking-[-0.02em] font-medium text-[11px] uppercase">
                <a class="text-[#DAC76A] font-bold border-b-2 border-[#DAC76A] pb-1" asp-controller="Flight" asp-action="Index">Explore</a>
                <a class="text-[#BFC5E4]/70 hover:text-[#DAC76A] transition-all duration-300" href="#">Bookings</a>
                <a class="text-[#BFC5E4]/70 hover:text-[#DAC76A] transition-all duration-300" href="#">Concierge</a>
                <a class="text-[#BFC5E4]/70 hover:text-[#DAC76A] transition-all duration-300" href="#">Lounges</a>
            </div>
            <div class="flex items-center gap-6">
                <button class="bg-[#F2F2F7] text-[#1C1C1E] font-bold py-2 px-6 rounded-full text-[10px] uppercase tracking-wider scale-95 active:scale-100 transition-transform">Elevate to First</button>
                <div class="flex items-center gap-4">
                    <button class="hover:text-[#DAC76A] transition-all duration-300">
                        <span class="material-symbols-outlined text-[#BFC5E4] text-xl">notifications</span>
                    </button>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                            <button type="submit" class="hover:text-[#DAC76A] transition-all duration-300 flex items-center gap-1" title="Sign Out">
                                <span class="material-symbols-outlined text-[#BFC5E4] text-xl">logout</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="hover:text-[#DAC76A] transition-all duration-300 flex items-center gap-1" title="Sign In">
                            <span class="material-symbols-outlined text-[#BFC5E4] text-xl">account_circle</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- Footer -->
    <footer class="bg-[#0B1229] w-full py-16 border-t border-[#BFC5E4]/10">
        <div class="flex flex-col md:flex-row justify-between items-center px-12 space-y-8 md:space-y-0 max-w-screen-2xl mx-auto">
            <div class="flex flex-col items-center md:items-start gap-2">
                <div class="flex items-center gap-3">
                    <img alt="SkyScan Logo" class="w-6 h-6 object-contain opacity-60" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDE3YoV-bTiqbWTeJ5H9ZF2xASvIl5pQvAFUdV7bL55V12L4dN4XEyRIVXFwZtR2g_vU7STh65kAHVvr9Q7zJiexI8ZwwfUvBDXLdgzEBdnjMDLMiG1inSnqltW_N7vSXX48JjoP7lT4NpRt6KTiJ6dPPBNf8Gl7mEyMBiEIbLf8kbZKT3T9dEx7CwRyl8W4DZcqXFchICzuoza_A2IXwkyBIp9tffc9wpL1gi1sE-cPjK71kDv28DSgFeXtwHG9f8tPUGOpkQUsQ" />
                    <span class="font-manrope font-bold text-[#BFC5E4]/60 text-lg">SkyScan</span>
                </div>
                <div class="font-inter text-[10px] uppercase tracking-[0.2em] leading-relaxed text-[#BFC5E4]/30">
                    © 2024 SkyScan Celestial Concierge. All rights reserved.
                </div>
            </div>
            <div class="flex gap-10 font-inter text-[10px] uppercase tracking-[0.2em] leading-relaxed">
                <a class="text-[#BFC5E4]/30 hover:text-[#DAC76A] transition-colors" href="#">Privacy Policy</a>
                <a class="text-[#BFC5E4]/30 hover:text-[#DAC76A] transition-colors" href="#">Terms of Service</a>
                <a class="text-[#BFC5E4]/30 hover:text-[#DAC76A] transition-colors" href="#">Luxury Partners</a>
                <a class="text-[#BFC5E4]/30 hover:text-[#DAC76A] transition-colors" href="#">Support</a>
            </div>
            <div class="flex items-center gap-4">
                <span class="material-symbols-outlined text-[#BFC5E4]/30 text-xl cursor-pointer hover:text-[#DAC76A]">language</span>
                <span class="text-[#DAC76A]/80 font-inter text-[10px] uppercase tracking-[0.2em] font-bold">Global Access</span>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
