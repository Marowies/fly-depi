<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyScan Pro</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-raised">

    <div class="d-flex flex-column min-vh-100">
        <header class="top-nav px-4 py-3 d-flex justify-content-between align-items-center mb-4">
            <div class="logo fw-bold text-primary fs-4">SkyScan Pro</div>
            <div class="text-secondary small">Welcome, @ViewData["UserName"]</div>
        </header>

        <div class="container-fluid flex-grow-1 px-4">
            <div class="row">
                <!-- Keep sidebar only if section is provided, else full width -->
                @if (IsSectionDefined("Sidebar"))
                {
                    <aside class="col-md-3 mb-4">
                        <div class="card-surface p-3 sticky-top" style="top: 20px;">
                            @RenderSection("Sidebar", required: false)
                        </div>
                    </aside>
                    <main class="col-md-9 mb-4">
                        <div class="card-surface p-4">
                            @RenderBody()
                        </div>
                    </main>
                }
                else
                {
                    <main class="col-12 mb-4">
                        <div class="card-surface p-4">
                            @RenderBody()
                        </div>
                    </main>
                }
            </div>
        </div>

        <footer class="mt-auto py-3 text-center text-secondary small bg-surface border-top">
            &copy; 2026 skyscan-pro.dev - High-Performance Aviation Platform
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>