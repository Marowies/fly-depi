        function setupAutocomplete(inputId, hiddenId, boxId, spinnerId, clearId) {
            const input = document.getElementById(inputId);
            const hidden = document.getElementById(hiddenId);
            const box = document.getElementById(boxId);
            const spinner = document.getElementById(spinnerId);
            const clearBtn = document.getElementById(clearId);
            let timeout = null;

            input.addEventListener('input', function() {
                const query = this.value.toLowerCase();
                clearBtn.style.display = query.length > 0 ? 'block' : 'none';
                
                // Reset hidden ID immediately when arbitrary typing occurs
                hidden.value = '';
                input.classList.remove('is-invalid');

                clearTimeout(timeout);
                if (query.length < 2) { 
                    box.style.display = 'none'; 
                    spinner.style.display = 'none';
                    return; 
                }

                spinner.style.display = 'block';

                timeout = setTimeout(() => {
                    // Simulate sub-100ms API call
                    const results = mockAirports.filter(a => a.text.toLowerCase().includes(query)).slice(0, 8);
                    
                    if (results.length > 0) {
                        box.innerHTML = results.map((item, idx) => `
                            <div class="suggestion-item" role="option" id="${inputId}-opt-${idx}" onclick="selectCity('${inputId}', '${hiddenId}', '${boxId}', '${item.value}', '${item.text}')">
                                <div>
                                    <span class="fw-bold">${item.text}</span>
                                </div>
                            </div>
                        `).join('');
                        box.style.display = 'block';
                        input.setAttribute('aria-expanded', 'true');
                    } else { 
                        box.style.display = 'none'; 
                        input.setAttribute('aria-expanded', 'false');
                    }
                    spinner.style.display = 'none';
                }, 80); // <100ms
            });

            // Handle Blur with arbitrary text check
            input.addEventListener('blur', () => { 
                setTimeout(() => { 
                    box.style.display = 'none'; 
                    input.setAttribute('aria-expanded', 'false');
                    
                    // Strict validation: if input has text but no hidden ID is set, it's invalid arbitrary text
                    if (input.value.trim().length > 0 && !hidden.value) {
                        input.classList.add('is-invalid');
                    } else {
                        input.classList.remove('is-invalid');
                    }
                }, 200); 
            });

            // Keyboard navigation
            input.addEventListener('keydown', function(e) {
                const items = box.querySelectorAll('.suggestion-item');
                if (items.length === 0 || box.style.display === 'none') return;
                
                let active = box.querySelector('.active');
                let activeIdx = Array.from(items).indexOf(active);

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if (active) active.classList.remove('active');
                    activeIdx = (activeIdx + 1) % items.length;
                    items[activeIdx].classList.add('active');
                    input.setAttribute('aria-activedescendant', items[activeIdx].id);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (active) active.classList.remove('active');
                    activeIdx = (activeIdx - 1 + items.length) % items.length;
                    items[activeIdx].classList.add('active');
                    input.setAttribute('aria-activedescendant', items[activeIdx].id);
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    if (active) {
                        active.click();
                    }
                } else if (e.key === 'Escape') {
                    box.style.display = 'none';
                }
            });
        }

        window.selectCity = function(inputId, hiddenId, boxId, cityId, cityName) {
            const input = document.getElementById(inputId);
            input.value = cityName;
            document.getElementById(hiddenId).value = cityId;
            document.getElementById(boxId).style.display = 'none';
            input.classList.remove('is-invalid');
            input.setAttribute('aria-expanded', 'false');
        }

        window.clearInput = function(prefix) {
            document.getElementById(`${prefix}Input`).value = '';
            document.getElementById(`${prefix}Id`).value = '';
            document.getElementById(`${prefix}Input`).classList.remove('is-invalid');
            document.getElementById(`${prefix}Clear`).style.display = 'none';
            document.getElementById(`${prefix}Input`).focus();
        }

        function swapDestinations() {
            const originInput = document.getElementById('OriginInput');
            const originId = document.getElementById('OriginId');
            const destInput = document.getElementById('DestInput');
            const destId = document.getElementById('DestId');

            const tempName = originInput.value; const tempId = originId.value;
            originInput.value = destInput.value; originId.value = destId.value;
            destInput.value = tempName; destId.value = tempId;
            
            // Re-validate if needed
            if (originInput.value && !originId.value) originInput.classList.add('is-invalid');
            else originInput.classList.remove('is-invalid');

            if (destInput.value && !destId.value) destInput.classList.add('is-invalid');
            else destInput.classList.remove('is-invalid');
        }

        function validateDates() {
            let isValid = true;
            const tripType = document.getElementById('TripTypeHidden').value;

            if (tripType === 'RoundTrip') {
                const dep = new Date(document.getElementById('DepDate').value);
                const retInput = document.getElementById('RetDate');
                const ret = new Date(retInput.value);

                if (retInput.value && ret < dep) {
                    retInput.classList.add('is-invalid');
                    isValid = false;
                } else {
                    retInput.classList.remove('is-invalid');
                }
            } else if (tripType === 'MultiWay') {
                const dates = Array.from(document.querySelectorAll('.mc-date'));
                let prevDate = null;
                
                dates.forEach(input => {
                    const current = new Date(input.value);
                    if (prevDate && current < prevDate) {
                        input.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        input.classList.remove('is-invalid');
                    }
                    if (input.value) prevDate = current;
                });
            }
            return isValid;
        }

        function validateForm() {
            let isValid = true;
            const tripType = document.getElementById('TripTypeHidden').value;

            if (tripType !== 'MultiWay') {
                const originId = document.getElementById('OriginId').value;
                const destId = document.getElementById('DestId').value;
                
                if (!originId) { document.getElementById('OriginInput').classList.add('is-invalid'); isValid = false; }
                if (!destId) { document.getElementById('DestInput').classList.add('is-invalid'); isValid = false; }
            } else {
                const inputs = document.querySelectorAll('#MultiCityLegsContainer .autocomplete-input');
                const hiddens = document.querySelectorAll('#MultiCityLegsContainer input[type="hidden"]');
                
                for(let i=0; i<inputs.length; i++) {
                    if (!hiddens[i].value) {
                        inputs[i].classList.add('is-invalid');
                        isValid = false;
                    }
                }
            }

            if (!validateDates()) isValid = false;

            return isValid;
        }
    </script>
}
