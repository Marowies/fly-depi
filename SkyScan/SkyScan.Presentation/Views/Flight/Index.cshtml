@model SkyScan.Presentation.Models.FlightSearchViewModel
@{
    ViewData["Title"] = "SkyScan - Premium Flight Experience";
    Layout = "_Layout";
}

<!-- Hero Canvas -->
<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20">
    <!-- Background Imagery with Dark Overlay -->
    <div class="absolute inset-0 z-0">
        <img class="w-full h-full object-cover" alt="ultra-luxury private jet cabin" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDvo3-nC_IOyG1LhxX6eREWDVtr017HJtBYfW7dGmMauwSsZCpZQKSIii0xBUz2PinJY810vxWxHOMZSP8WXxlf9Uq_I8dvqbR6TJHOek5S-IYW5-YADULfFUqMFaoiEhe7B1RCrLUSLlu4ZUVXoEL93hfIqgquw4S-eK4cbyFX7ZP-wMhnIo3hQoVDL9oCqyHdRwYnbM6EwulQEqezYBZop00qLNLFM9f4pWehMaXO7wa5fvJPP6fW_jUtuxoEciOrXO6YATxDIQ" />
        <div class="absolute inset-0 bg-gradient-to-b from-background/40 via-background/60 to-background"></div>
    </div>
    
    <!-- Hero Content Section -->
    <section class="relative z-10 w-full max-w-7xl px-8 flex flex-col items-start gap-12">
        <div class="max-w-3xl">
            <h1 class="font-headline text-5xl md:text-[80px] font-extrabold tracking-tighter text-on-surface leading-[1.0] mb-8">
                SKYSCAN: WHERE TO <br /><span class="text-primary italic font-light opacity-90">NEXT?</span>
            </h1>
            <p class="text-on-surface-variant text-lg md:text-xl font-light max-w-xl leading-relaxed opacity-80">
                Experience the zenith of aviation with SkyScan. Curated itineraries for those who view the horizon not as a boundary, but as a beginning.
            </p>
        </div>

        <!-- Floating Glassmorphism Search Engine -->
        <form asp-controller="Flight" asp-action="Search" method="post" id="searchForm" class="w-full">
            <input type="hidden" asp-for="TripType" id="TripTypeHidden" value="OneWay" />
            
            <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4 font-bold bg-red-950/20 p-4 rounded-xl border border-red-500/20 backdrop-blur-md"></div>

            <div class="w-full glass-panel rounded-2xl p-1 md:p-2 border border-outline-variant/10">
                <!-- Standard Search (OneWay / RoundTrip) -->
                <div id="StandardSearchFields" class="flex flex-col lg:flex-row items-stretch gap-1">
                    <!-- Origin -->
                    <div class="flex-1 bg-surface-container-low/60 hover:bg-surface-container-high transition-colors p-6 rounded-xl group relative">
                        <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Origin</label>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary text-xl">flight_takeoff</span>
                            <input asp-for="OriginCity" list="cityList" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl placeholder:text-on-surface-variant/30 w-full uppercase outline-none" placeholder="Enter City..." type="text" />
                        </div>
                    </div>
                    <!-- Destination -->
                    <div class="flex-1 bg-surface-container-low/60 hover:bg-surface-container-high transition-colors p-6 rounded-xl group relative">
                        <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Destination</label>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-tertiary text-xl">location_on</span>
                            <input asp-for="DestinationCity" list="cityList" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl placeholder:text-on-surface-variant/30 w-full uppercase outline-none" placeholder="Enter City..." type="text" />
                        </div>
                    </div>
                    <!-- Departure -->
                    <div class="flex-1 bg-surface-container-low/60 hover:bg-surface-container-high transition-colors p-6 rounded-xl group relative">
                        <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Departure</label>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary text-xl">calendar_today</span>
                            <input asp-for="DepartureDate" type="date" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl w-full outline-none text-light" />
                        </div>
                    </div>
                    <!-- Return Date -->
                    <div id="ReturnDateField" class="flex-1 bg-surface-container-low/60 hover:bg-surface-container-high transition-colors p-6 rounded-xl group relative" style="display: none;">
                        <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Return</label>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-tertiary text-xl">event_repeat</span>
                            <input asp-for="ReturnDate" type="date" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl w-full outline-none [color-scheme:dark]" />
                        </div>
                    </div>
                    <!-- Cabin Class -->
                    <div class="flex-1 bg-surface-container-low/60 hover:bg-surface-container-high transition-colors p-6 rounded-xl group relative">
                        <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Cabin Class</label>
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary text-xl">star</span>
                            <select asp-for="CabinClass" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl w-full cursor-pointer appearance-none uppercase outline-none">
                                <option value="first" class="bg-surface-container-high text-white">First Class</option>
                                <option value="business" class="bg-surface-container-high text-white">Business</option>
                                <option value="premium" class="bg-surface-container-high text-white">Premium</option>
                                <option value="economy" class="bg-surface-container-high text-white">Economy</option>
                            </select>
                            
                        </div>
                    </div>
                    <!-- CTA -->
                    <button type="submit" class="bg-[#BFC5E4] hover:bg-white text-[#292F48] font-headline font-bold uppercase tracking-widest text-lg px-12 py-6 lg:py-0 rounded-xl transition-all active:scale-[0.98]">
                        Explore
                    </button>
                </div>

                <!-- Multi-City Search -->
                <div id="MultiCitySearchFields" class="p-4 space-y-4" style="display: none;">
                    <div id="MultiCityLegsContainer" class="space-y-4">
                        <!-- Legs will be added here -->
                    </div>
                    <div class="flex justify-between items-center mt-6">
                        <button type="button" onclick="addMultiCityLeg()" class="flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest hover:text-white transition-colors">
                            <span class="material-symbols-outlined text-lg">add_circle</span>
                            Add Destination
                        </button>
                        <button type="submit" class="bg-[#BFC5E4] hover:bg-white text-[#292F48] font-headline font-bold uppercase tracking-widest text-lg px-16 py-4 rounded-xl transition-all active:scale-[0.98]">
                            Explore Journey
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- Quick Filter Chips -->
            <div class="flex flex-wrap gap-4 mt-6 ml-2">
                <button type="button" onclick="setTripType('OneWay')" id="btnOneWay" class="trip-type-btn bg-white text-black px-6 py-2 rounded-full font-label text-[10px] uppercase tracking-widest font-bold cursor-pointer transition-all">One Way</button>
                <button type="button" onclick="setTripType('RoundTrip')" id="btnRoundTrip" class="trip-type-btn bg-white/10 text-white/40 px-6 py-2 rounded-full font-label text-[10px] uppercase tracking-widest font-bold cursor-pointer hover:bg-white/20 transition-all">Round Trip</button>
                <button type="button" onclick="setTripType('MultiWay')" id="btnMultiWay" class="trip-type-btn bg-white/10 text-white/40 px-6 py-2 rounded-full font-label text-[10px] uppercase tracking-widest font-bold cursor-pointer hover:bg-white/20 transition-all">Multi-City</button>
                <div class="flex items-center gap-2 ml-auto text-[#DAC76A] cursor-pointer hover:opacity-80 transition-opacity">
                    <span class="material-symbols-outlined text-lg">auto_awesome</span>
                    <span class="font-label text-[10px] uppercase tracking-widest font-bold">SkyScan VIP Concierge</span>
                </div>
            </div>
            
            <!-- City List Datalist -->
            <datalist id="cityList">
                @if (Model.CitiesWithAirports != null)
                {
                    foreach (var city in Model.CitiesWithAirports)
                    {
                        <option value="@city.Text"></option>
                    }
                }
            </datalist>
        </form>
    </section>
</main>

<!-- Template for Multi-City Leg -->
<template id="MultiCityLegTemplate">
    <div class="multi-city-leg flex flex-col lg:flex-row items-stretch gap-1 animate-in fade-in slide-in-from-left-4 duration-500">
        <div class="flex-1 bg-surface-container-low/60 p-6 rounded-xl group relative border border-white/5">
            <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Leg {index} Origin</label>
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-xl">flight_takeoff</span>
                <input name="MultiCityLegs[{index}].OriginCity" list="cityList" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl placeholder:text-on-surface-variant/30 w-full uppercase outline-none" placeholder="CITY" required />
            </div>
        </div>
        <div class="flex-1 bg-surface-container-low/60 p-6 rounded-xl group relative border border-white/5">
            <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Destination</label>
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-tertiary text-xl">location_on</span>
                <input name="MultiCityLegs[{index}].DestinationCity" list="cityList" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl placeholder:text-on-surface-variant/30 w-full uppercase outline-none" placeholder="CITY" required />
            </div>
        </div>
        <div class="flex-1 bg-surface-container-low/60 p-6 rounded-xl group relative border border-white/5">
            <label class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold">Departure</label>
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-xl">calendar_today</span>
                <input name="MultiCityLegs[{index}].DepartureDate" type="date" class="bg-transparent border-none p-0 focus:ring-0 text-on-surface font-headline font-bold text-xl w-full outline-none [color-scheme:dark]" required />
            </div>
        </div>
        <button type="button" onclick="removeMultiCityLeg(this)" class="bg-red-500/10 hover:bg-red-500/20 text-red-500 px-6 rounded-xl transition-all">
            <span class="material-symbols-outlined">delete</span>
        </button>
    </div>
</template>

