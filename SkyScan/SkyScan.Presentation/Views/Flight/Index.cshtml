<!-- Luxury Stats -->
<section class="bg-background py-24 px-8 border-t border-white/5">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-16">
        <div class="text-center md:text-left space-y-2">
            <div class="text-tertiary font-headline text-6xl font-extrabold tracking-tighter">98.4%</div>
            <div class="font-label text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold">SkyScan On-Time Arrival</div>
        </div>
        <div class="w-px h-16 bg-white/10 hidden md:block"></div>
        <div class="text-center md:text-left space-y-2">
            <div class="text-white font-headline text-6xl font-extrabold tracking-tighter">150+</div>
            <div class="font-label text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold">Global SkyScan Lounges</div>
        </div>
        <div class="w-px h-16 bg-white/10 hidden md:block"></div>
        <div class="text-center md:text-left space-y-2">
            <div class="text-white font-headline text-6xl font-extrabold tracking-tighter">24/7</div>
            <div class="font-label text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold">SkyScan Concierge</div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        let multiCityCount = 0;

        function setTripType(type) {
            document.getElementById('TripTypeHidden').value = type;
            const buttons = document.querySelectorAll('.trip-type-btn');
            buttons.forEach(btn => {
                btn.classList.remove('bg-white', 'text-black');
                btn.classList.add('bg-white/10', 'text-white/40');
            });
            const selectedBtn = document.getElementById('btn' + type);
            if (selectedBtn) {
                selectedBtn.classList.remove('bg-white/10', 'text-white/40');
                selectedBtn.classList.add('bg-white', 'text-black');
            }

            // Toggle Search Fields
            const standardFields = document.getElementById('StandardSearchFields');
            const multiCityFields = document.getElementById('MultiCitySearchFields');
            const returnField = document.getElementById('ReturnDateField');

            if (type === 'MultiWay') {
                standardFields.style.display = 'none';
                multiCityFields.style.display = 'block';
                if (multiCityCount === 0) {
                    addMultiCityLeg();
                    addMultiCityLeg();
                }
            } else {
                standardFields.style.display = 'flex';
                multiCityFields.style.display = 'none';
                returnField.style.display = (type === 'RoundTrip') ? 'block' : 'none';
            }
        }

        function addMultiCityLeg() {
            const container = document.getElementById('MultiCityLegsContainer');
            const template = document.getElementById('MultiCityLegTemplate').innerHTML;
            const legHtml = template.replace(/{index}/g, multiCityCount);
            
            const div = document.createElement('div');
            div.innerHTML = legHtml;
            container.appendChild(div.firstElementChild);
            multiCityCount++;
        }

        function removeMultiCityLeg(btn) {
            if (document.querySelectorAll('.multi-city-leg').length > 2) {
                btn.closest('.multi-city-leg').remove();
            } else {
                alert('SkyScan Premium: Minimum 2 legs required for Multi-City itineraries.');
            }
        }
        
        // Check TripType from Model on load
        window.addEventListener('load', () => {
            const initialType = "@Model.TripType";
            setTripType(initialType);
        });
    </script>
}
